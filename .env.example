# =============================================================================
# ForgeFlow AI - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- App ---
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key

# --- Database ---
DB_URL=postgresql+asyncpg://forgeflow:forgeflow_dev@localhost:5432/forgeflow
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# --- Redis ---
REDIS_URL=redis://:redis_dev@localhost:6379/0

# --- LLM: DeepSeek (primary) ---
LLM__DEFAULT_PROVIDER=deepseek
LLM__DEFAULT_MODEL=deepseek-chat
LLM__COMPLEX_MODEL=deepseek-chat
LLM__DEEPSEEK_API_KEY=sk-your-deepseek-api-key
LLM__DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- LLM: OpenAI ---
LLM__OPENAI_API_KEY=sk-your-openai-api-key
LLM__EMBEDDING_MODEL=text-embedding-3-small

# --- LLM: Anthropic (optional) ---
LLM__ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# --- LLM: Qwen / Alibaba (optional, Phase 1+) ---
LLM__QWEN_API_KEY=your-qwen-api-key

# --- Shopify ---
SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret
SHOPIFY_SCOPES=read_orders,write_orders,read_customers,read_fulfillments
SHOPIFY_OAUTH_REDIRECT_URI=http://localhost:3000/auth/shopify/callback

# --- Security ---
# Comma-separated list of allowed CORS origins (production only)
# In development, localhost:3000 and 127.0.0.1:3000 are automatically allowed
CORS_ORIGINS=https://app.forgeflow.ai
# Rate limiting (set to false to disable, useful for load testing)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_IP_MINUTE=120

# --- Observability ---
SENTRY_DSN=
OTEL_ENDPOINT=

# --- Next.js Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- Shopify E2E Testing (optional, for local integration tests) ---
# SHOPIFY_E2E_ENABLED=true
# SHOPIFY_E2E_SHOP_DOMAIN=test-store.myshopify.com
# SHOPIFY_E2E_ACCESS_TOKEN=shpat_xxxxxxxxxxxx
# SHOPIFY_E2E_ORDER_ID=1234567890
# SHOPIFY_E2E_CUSTOMER_EMAIL=test@test.com
