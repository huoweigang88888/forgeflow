# =============================================================================
# ForgeFlow AI - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- App ---
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key

# --- Database ---
DB_URL=postgresql+asyncpg://forgeflow:forgeflow_dev@localhost:5432/forgeflow
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# --- Redis ---
REDIS_URL=redis://:redis_dev@localhost:6379/0

# --- LLM: DeepSeek (primary) ---
LLM_DEFAULT_PROVIDER=deepseek
LLM_DEFAULT_MODEL=deepseek-chat
LLM_COMPLEX_MODEL=deepseek-chat
LLM_DEEPSEEK_API_KEY=sk-your-deepseek-api-key
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- LLM: OpenAI ---
LLM_OPENAI_API_KEY=sk-your-openai-api-key
LLM_EMBEDDING_MODEL=text-embedding-3-small

# --- LLM: Anthropic (optional) ---
LLM_ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# --- LLM: Qwen / Alibaba (optional, Phase 1+) ---
LLM_QWEN_API_KEY=your-qwen-api-key

# --- Shopify ---
SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret
SHOPIFY_SCOPES=read_orders,write_orders,read_customers,read_fulfillments

# --- Observability ---
SENTRY_DSN=
OTEL_ENDPOINT=

# --- Next.js Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
