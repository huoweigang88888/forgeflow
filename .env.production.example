# =============================================================================
# ForgeFlow AI - Production Environment Variables
# =============================================================================
# Copy this to .env.production and fill in real values.
# NEVER commit secrets to version control.

# --- App ---
APP_ENV=production
DEBUG=false
SECRET_KEY=change-me-to-a-secure-random-64-char-string

# --- Database (Production) ---
DB_URL=postgresql+asyncpg://forgeflow:CHANGE_ME@postgres:5432/forgeflow
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_ECHO=false

# --- Redis (Production) ---
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# --- LLM Configuration ---
# Primary: DeepSeek (cost-effective for high volume)
LLM_DEFAULT_PROVIDER=deepseek
LLM_DEFAULT_MODEL=deepseek-chat
LLM_COMPLEX_MODEL=deepseek-chat
LLM_DEEPSEEK_API_KEY=sk-your-deepseek-api-key
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com

# Fallback: OpenAI (for complex decisions)
LLM_OPENAI_API_KEY=sk-your-openai-api-key

# Embeddings
LLM_EMBEDDING_PROVIDER=openai
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_EMBEDDING_DIMENSIONS=1536

# --- Agent Settings ---
LLM_AUTO_REFUND_THRESHOLD=50.00
LLM_SIMILARITY_THRESHOLD=0.85

# --- Shopify OAuth ---
SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret
SHOPIFY_SCOPES=read_orders,write_orders,read_customers,read_fulfillments

# --- JWT / Security ---
JWT_SECRET_KEY=change-me-to-a-different-secure-random-key
JWT_EXPIRATION_MINUTES=1440
AES_ENCRYPTION_KEY=change-me-to-a-32-byte-base64-encoded-key

# --- Email (SendGrid / SMTP) ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
SMTP_FROM_EMAIL=noreply@forgeflow.ai
SMTP_FROM_NAME=ForgeFlow AI

# --- Observability ---
SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/xxx
OTEL_ENDPOINT=https://your-otel-collector:4317

# --- Audit ---
AUDIT_LOG_RETENTION_DAYS=365

# --- Rate Limiting ---
RATE_LIMIT_TICKETS_PER_MIN=100
RATE_LIMIT_STATUS_PER_MIN=300
RATE_LIMIT_WS_PER_MIN=50

# --- Next.js Frontend (for CORS) ---
FRONTEND_URL=https://app.forgeflow.ai
